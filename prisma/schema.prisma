generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String        @id @default(cuid())
  name         String
  email        String        @unique
  password     String
  role         Role          @default(BORROWER)
  phone        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  applications Application[]

  @@map("users")
}

model Application {
  id             String            @id @default(cuid())
  userId         String
  fullName       String
  dateOfBirth    DateTime
  address        String
  phone          String
  employmentType String
  employer       String?
  monthlyIncome  Float
  yearsEmployed  Float
  amount         Float
  tenure         Int               @default(12)
  purpose        String
  interestRate   Float             @default(12.0)
  creditScore    Int?
  status         ApplicationStatus @default(PENDING)
  reviewNote     String?
  reviewedBy     String?
  reviewedAt     DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents      Document[]
  loan           Loan?

  @@map("applications")
}

model Document {
  id            String       @id @default(cuid())
  applicationId String
  type          DocumentType
  fileName      String
  fileUrl       String
  fileSize      Int?
  uploadedAt    DateTime     @default(now())
  application   Application  @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("documents")
}

model Loan {
  id                 String        @id @default(cuid())
  applicationId      String        @unique
  principal          Float
  interestRate       Float
  tenureMonths       Int
  monthlyEMI         Float
  totalInterest      Float
  totalAmount        Float
  outstandingBalance Float
  status             LoanStatus    @default(ACTIVE)
  disbursedAt        DateTime      @default(now())
  closedAt           DateTime?
  delinquentNotes    String?
  escrowBalance      Float         @default(0)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  emis               EMI[]
  escrowEntries      EscrowEntry[]
  application        Application   @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  transactions       Transaction[]

  @@map("loans")
}

model EMI {
  id                 String       @id @default(cuid())
  loanId             String
  emiNumber          Int
  dueDate            DateTime
  principalComponent Float
  interestComponent  Float
  amount             Float
  outstandingAfter   Float
  status             EMIStatus    @default(DUE)
  paidAt             DateTime?
  loan               Loan         @relation(fields: [loanId], references: [id], onDelete: Cascade)
  transaction        Transaction?

  @@map("emis")
}

model Transaction {
  id        String   @id @default(cuid())
  loanId    String
  emiId     String?  @unique
  amount    Float
  method    String   @default("ONLINE")
  paidAt    DateTime @default(now())
  reference String?
  emi       EMI?     @relation(fields: [emiId], references: [id])
  loan      Loan     @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@map("transactions")
}

model EscrowEntry {
  id           String          @id @default(cuid())
  loanId       String
  type         EscrowEntryType
  amount       Float
  description  String?
  balanceAfter Float
  createdAt    DateTime        @default(now())
  loan         Loan            @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@map("escrow_entries")
}

enum Role {
  BORROWER
  ADMIN
}

enum ApplicationStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
}

enum LoanStatus {
  ACTIVE
  CLOSED
  DELINQUENT
}

enum EMIStatus {
  DUE
  PAID
  OVERDUE
}

enum DocumentType {
  ID_PROOF
  INCOME_PROOF
  BANK_STATEMENT
  OTHER
}

enum EscrowEntryType {
  DEPOSIT
  WITHDRAWAL
}
